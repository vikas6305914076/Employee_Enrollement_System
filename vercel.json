{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "destination": "/login.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/auth/:path*",
      "destination": "https://employeeenrollementsystem-production.up.railway.app/auth/:path*"
    },
    {
      "source": "/employees",
      "destination": "https://employeeenrollementsystem-production.up.railway.app/employees"
    },
    {
      "source": "/employees/:path*",
      "destination": "https://employeeenrollementsystem-production.up.railway.app/employees/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/src/main/resources/static/$1"
    }
  ]
}
